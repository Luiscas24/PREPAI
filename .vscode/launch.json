{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "👁️ Iniciar Todo: Servidor + Chrome",
      // Esta configuración arranca tu servidor de desarrollo (Next.js) 
      // y abre la previsualización nativa de Chrome u oculta la terminal de Chrome.
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "preLaunchTask": "limpiar-sesion-dev", // Tarea oculta que mata cualquier localhost:3000 previo
      "serverReadyAction": {
        "pattern": "Local.*https://localhost",
        "uriFormat": "https://localhost:3000",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "👁️ Solo Chrome (Servidor activo)",
      // Utiliza esta configuración si arrancaste 'npm run dev' manualmente en otra terminal.
      "type": "chrome",
      "request": "launch",
      "url": "https://localhost:3000",
      "runtimeArgs": [
        "--force-dark-mode" // Borra o comenta (//) esta línea para probar el modo Claro (Light Mode) en Chrome
      ],
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "🦊 Iniciar Todo: Servidor + Firefox",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev & sleep 10 && open -na 'Firefox Developer Edition' https://localhost:3000",
      "preLaunchTask": "limpiar-sesion-dev"
    },
    {
      "name": "🦊 Solo Firefox (Servidor activo)",
      "type": "node-terminal",
      "request": "launch",
      "command": "open -na 'Firefox Developer Edition' --args https://localhost:3000",
      "preLaunchTask": "limpiar-firefox"
    }
  ]
}